# ４0代からできるAI攻略 — 環境変数サンプル
# このファイルをコピーして .env.local を作成してください（.env.local は git 管理外）。

# 必須: Anthropic Claude APIキー（サーバー側のみで使用）
ANTHROPIC_API_KEY=sk-ant-...

# 任意: 使用モデル（既定 claude-opus-4-8）。
# 無料枠のコストを抑えたい場合は claude-haiku-4-5 などに変更可。
# CLAUDE_MODEL=claude-opus-4-8

# 任意: 1回の応答の最大トークン（既定 2048）
# CLAUDE_MAX_TOKENS=2048

# 任意: 無料枠の1日あたり回数（既定 5）
# FREE_DAILY_LIMIT=5
